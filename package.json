{
  "name": "alaz-nestjs-mcp",
  "version": "1.0.0",
  "description": "Alaz MCP Server — Living project context for AI agents",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:stdio": "ts-node -r tsconfig-paths/register src/mcp/feature/mcp-stdio.entry.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/platform-express": "^11",
    "@rekog/mcp-nest": "^1.9.7",
    "glob": "^11",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@nestjs/cli": "^11",
    "@nestjs/testing": "^11",
    "@types/express": "^5.0.6",
    "@types/jest": "^29",
    "@types/node": "^22",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-prettier": "^5",
    "globals": "^15",
    "jest": "^29",
    "prettier": "^3",
    "ts-jest": "^29",
    "ts-node": "^10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9",
    "typescript-eslint": "^8"
  }
}

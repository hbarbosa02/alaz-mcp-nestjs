{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@test/*": ["test/*"],
      "@mcp/core/*": ["src/mcp/core/*"],
      "@mcp/domain/nestjs/*": ["src/mcp/domain/nestjs/*"],
      "@mcp/domain/angular/*": ["src/mcp/domain/angular/*"],
      "@mcp/domain/laravel/*": ["src/mcp/domain/laravel/*"],
      "@mcp/domain/shared/*": ["src/mcp/domain/shared/*"],
      "@mcp/util/*": ["src/mcp/util/*"]
    },
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true
  }
}
